# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/ipl_nexus?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# GROK AI (xAI)
GROK_API_KEY=your_grok_api_key_here
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-beta

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin defaults (used for initial seed)
ADMIN_EMAIL=admin@iplnexus.com
ADMIN_PASSWORD=Admin@IPL2025!

# Auction defaults
MAX_TEAM_PURSE=100
MAX_BASE_PRICE=15
BID_INCREMENT=0.15
TIMER_SECONDS=10
